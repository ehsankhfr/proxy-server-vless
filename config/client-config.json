{
  "inbounds": [
    {
      "port": 1080,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "YOUR_AWS_EC2_PUBLIC_IP",
            "port": 80,
            "users": [
              {
                "id": "YOUR_STABLE_UUID_FROM_CDK_OUTPUT",
                "encryption": "none",
                "level": 0
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "path": "/vless-fallback",
          "headers": {
            "Host": "YOUR_AWS_EC2_PUBLIC_IP"
          }
        }
      }
    }
  ]
}
          }
        }
      }
    }
  ]
}
